            transform: scale(0.97);
        }

        
        .cart-bottom {
            position: fixed;
            bottom: 28px;
            left: 28px;
            background: #1e160fe8;
            backdrop-filter: blur(12px);
            border-radius: 70px;
            padding: 12px 26px;
