<script>

    let cart = [];  

    
    function updateCartStorage() {
        localStorage.setItem('peculiar_cart', JSON.stringify(cart));
        const totalQty = cart.reduce((sum, i) => sum + i.quantity, 0);
        document.getElementById('cartCounter').innerText = totalQty;
    }

    function loadCartFromStorage() {
        const stored = localStorage.getItem('peculiar_cart');
        if (stored) {
            try {
                cart = JSON.parse(stored);
            } catch(e) { cart = []; }
        } else { cart = []; }
        const totalQty = cart.reduce((sum, i) => sum + i.quantity, 0);
        document.getElementById('cartCounter').innerText = totalQty;
    }

    
    function addItemToCart(product) {
        const existing = cart.find(item => item.id === product.id);
        if (existing) {
            existing.quantity += 1;
        } else {
            cart.push({ ...product, quantity: 1 });
        }
        updateCartStorage();
        
        const cartDiv = document.getElementById('cartIcon');
        cartDiv.style.transform = 'scale(1.1)';
        setTimeout(() => { if(cartDiv) cartDiv.style.transform = ''; }, 180);
    }

    
    function renderCartModal() {
        const container = document.getElementById('cartItemsList');
        const totalContainer = document.getElementById('cartTotalBox');
        if (!container) return;
        if (cart.length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:36px;">🐾 No items yet. Discover cardigans, loafers, hypercars, shorts & luxury watches. 🐾</div>';
            totalContainer.innerHTML = '';
            return;
        }
        let html = '<ul style="list-style:none;">';
        let totalAmount = 0;
        cart.forEach(item => {
            const itemTotal = item.price * item.quantity;
            totalAmount += itemTotal;
            html += `
                <li>
                    <div><strong>${item.name}</strong> <span style="color:#f7cf7a;">x${item.quantity}</span><br><small>$${item.price.toLocaleString()} each</small></div>
                    <div>$${itemTotal.toLocaleString()} <button class="remove-item-btn" data-id="${item.id}" style="background:#b47839; border:none; border-radius:40px; padding:5px 16px; margin-left:12px; cursor:pointer;">✖ Remove one</button></div>
                </li>
            `;
        });
        html += '</ul>';
        container.innerHTML = html;
        totalContainer.innerHTML = `<span>💰 TOTAL: $${totalAmount.toLocaleString()} USD</span>`;


        document.querySelectorAll('.remove-item-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = parseInt(btn.getAttribute('data-id'));
                const index = cart.findIndex(i => i.id === id);
                if (index !== -1) {
                    if (cart[index].quantity > 1) cart[index].quantity -= 1;
                    else cart.splice(index, 1);
                    updateCartStorage();
                    renderCartModal();   
                }
                e.stopPropagation();
            });
        });
    }

    
    function showPurchasePage() {
        if (cart.length === 0) {
            alert("⚠️ Your cart is empty. Please add some peculiar items before purchase.");
            return;
        }
        const totalPrice = cart.reduce((sum, i) => sum + (i.price * i.quantity), 0);
        const modalDiv = document.querySelector('#cartModal .modal-panel');
        const originalHTML = modalDiv.innerHTML;

        const purchaseHTML = `
            <h2>💳 COMPLETE YOUR PURCHASE</h2>
            <div style="background:#2d241c; border-radius: 36px; padding: 24px; margin: 20px 0;">
                <p style="font-size:1.5rem; font-weight:bold;">ORDER SUMMARY</p>
                ${cart.map(i => `<div style="display:flex; justify-content:space-between; border-bottom:1px solid #daa65a; padding:12px 0;"><span>${i.name} (x${i.quantity})</span><span>$${(i.price * i.quantity).toLocaleString()}</span></div>`).join('')}
                <div style="font-size:1.9rem; margin-top: 24px; text-align:right;"><strong>Total: $${totalPrice.toLocaleString()}</strong></div>
                <p style="margin-top: 15px;">🔐 Secure gateway · express worldwide shipping</p>
                <button id="confirmOrderPurchase" style="background:#eeb25e; width:100%; padding:14px; border:none; border-radius:80px; font-weight:bold; margin-top:28px;">✅ CONFIRM & PAY ✅</button>
                <button id="backToCartFromPurchase" style="background:#4d3622; width:100%; padding:12px; border:none; border-radius:80px; margin-top:12px;">← Back to Cart</button>
            </div>
        `;
        modalDiv.innerHTML = purchaseHTML;

        const confirmBtn = document.getElementById('confirmOrderPurchase');
        const backBtn = document.getElementById('backToCartFromPurchase');

        const restoreCartModalUI = () => {
            modalDiv.innerHTML = originalHTML;
        
            document.getElementById('closeCartBtn').onclick = () => document.getElementById('cartModal').style.display = 'none';
            document.getElementById('checkoutPurchaseBtn').onclick = () => showPurchasePage();
            renderCartModal();
        };

        if (confirmBtn) {
            confirmBtn.onclick = () => {
                alert(`🎉 PURCHASE COMPLETED! 🎉\nTotal: $${totalPrice.toLocaleString()}\nThank you for shopping at Peculiar Media. Your luxury items are confirmed.`);
                cart = [];
                updateCartStorage();
                restoreCartModalUI();
                document.getElementById('cartModal').style.display = 'none';
                renderCartModal();
            };
        }
        if (backBtn) backBtn.onclick = () => restoreCartModalUI();
    }


    function bindAddToCartButtons() {
        const allBuyBtns = document.querySelectorAll('.buy-now-btn');
        allBuyBtns.forEach(btn => {
            btn.removeEventListener('click', window._handler);
            const clickHandler = (e) => {
                const card = btn.closest('.product-card');
                if (card && card.dataset.product) {
                    const prod = JSON.parse(card.dataset.product);
                    addItemToCart(prod);
                }
            };
            btn.addEventListener('click', clickHandler);
            window._handler = clickHandler;
        });
    }

    
    function initAngleGallery() {
        const angleImages = document.querySelectorAll('.angle-img');
        angleImages.forEach(img => {
            img.addEventListener('click', () => {
                const targetId = img.getAttribute('data-target');
                const mainImg = document.getElementById(targetId);
                if (mainImg) {
                    const tempSrc = mainImg.src;
                    mainImg.src = img.src;
                    img.src = tempSrc;  
                    
                    mainImg.src = img.src;
                }
            });
        });
    }

    // ---- MODALS ----
    const cartModalEl = document.getElementById('cartModal');
