<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Peculiar Media | Golf le Fleur · Luxury Exotics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #070401;
            font-family: 'Inter', 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: #f5ecdb;
            min-height: 100vh;
            position: relative;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 18% 32%, rgba(80, 48, 25, 0.65) 3px, transparent 3px),
                radial-gradient(circle at 72% 68%, rgba(100, 58, 28, 0.55) 4px, transparent 4px),
                repeating-radial-gradient(circle at 45% 55%, rgba(70, 42, 20, 0.5) 0px, rgba(70, 42, 20, 0.5) 2px, transparent 2px, transparent 16px),
                repeating-linear-gradient(125deg, #24180e 0px, #24180e 2px, #140e07 2px, #140e07 48px);
            background-size: 75px 75px, 95px 95px, 40px 40px, auto;
            pointer-events: none;
            z-index: -2;
        }
        body::after {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.25) 0%, #0a0500 90%);
            pointer-events: none;
            z-index: -1;
        }

        .wrapper {
            max-width: 1480px;
            margin: 0 auto;
            padding: 0 28px 110px 28px;
            position: relative;
            z-index: 2;
        }

        .header-area {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 32px 0 24px;
            border-bottom: 2px solid rgba(200, 145, 70, 0.6);
            flex-wrap: wrap;
            gap: 20px;
        }

        .site-title {
            flex: 1;
            text-align: center;
            font-size: 2.3rem;
            font-weight: 800;
            letter-spacing: 5px;
            text-transform: uppercase;
            background: linear-gradient(135deg, #faeec9, #e0b062, #fbd896);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 2px 7px rgba(0,0,0,0.6);
            font-family: 'Inter', sans-serif;
        }

        .about-btn {
            background: #2c1f13;
            border: 1.8px solid #cb984b;
            padding: 10px 30px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.9rem;
            color: #fae2ae;
            cursor: pointer;
            transition: 0.25s;
            font-family: inherit;
            backdrop-filter: blur(4px);
        }

        .about-btn:hover {
            background: #d6a251;
            color: #120e07;
            border-color: #fff0bc;
            transform: scale(1.02);
            box-shadow: 0 6px 14px rgba(0,0,0,0.45);
        }


        .products-five {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 28px;
            margin: 58px 0 64px;
        }

        .product-card {
            background: rgba(20, 14, 8, 0.88);
            backdrop-filter: blur(6px);
            border-radius: 38px;
            padding: 22px 16px 24px;
            transition: all 0.3s ease;
            border: 1px solid rgba(190, 135, 60, 0.65);
            box-shadow: 0 25px 32px -16px black;
            text-align: center;
            display: flex;
            flex-direction: column;
        }

        .product-card:hover {
            transform: translateY(-8px);
            border-color: #eebb66;
            background: rgba(32, 22, 13, 0.96);
            box-shadow: 0 30px 40px -14px #000000cc;
        }

        .angle-gallery {
            display: flex;
            gap: 6px;
            justify-content: center;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }
        .angle-img {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: 14px;
            border: 1px solid #cb984b;
            background: #2e2116;
            transition: 0.2s;
            cursor: pointer;
        }
        .main-product-img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 28px;
            background: #352618;
            margin-bottom: 14px;
            box-shadow: 0 8px 18px rgba(0,0,0,0.6);
            transition: 0.2s;
        }
        .product-title {
            font-size: 1.22rem;
            font-weight: 800;
            margin: 6px 0 4px;
            color: #fff2dc;
        }
        .product-desc {
            font-size: 0.7rem;
            color: #e6c68b;
            margin-bottom: 10px;
        }
        .price {
            font-size: 1.6rem;
            font-weight: 800;
            color: #f8cf7a;
            margin: 6px 0;
        }
        .buy-now-btn {
            background: #3f2b18;
            border: none;
            padding: 10px 12px;
            border-radius: 60px;
            font-weight: bold;
            color: #fff7e6;
            font-size: 0.85rem;
