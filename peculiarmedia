        }
        .cart-count {
            background: #ffc670;
            color: #20160d;
            font-weight: 800;
            font-size: 1.2rem;
            border-radius: 60px;
            padding: 2px 16px;
            min-width: 46px;
            text-align: center;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(14px);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }
        .modal-panel {
            background: #241f18;
            max-width: 800px;
            width: 92%;
            max-height: 85vh;
            border-radius: 52px;
            padding: 32px 30px;
            border: 1px solid #e0aa5a;
            box-shadow: 0 40px 60px black;
            overflow-y: auto;
            color: #f7ecdb;
        }
        .modal-panel h2 {
            font-size: 2rem;
            font-weight: 700;
            border-left: 6px solid #f3be6b;
            padding-left: 20px;
            margin-bottom: 28px;
        }
        .cart-list-ul {
            list-style: none;
            margin: 20px 0;
        }
        .cart-list-ul li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #362b20;
            margin: 12px 0;
            padding: 12px 20px;
            border-radius: 100px;
            border-left: 5px solid #f1b761;
            flex-wrap: wrap;
            gap: 10px;
        }
        .remove-one {
            background: #ba7d3e;
            border: none;
            border-radius: 40px;
            padding: 5px 18px;
            font-weight: bold;
            cursor: pointer;
            color: #22180f;
        }
        .total-price {
            font-size: 1.8rem;
            font-weight: 800;
            text-align: right;
            margin-top: 20px;
            border-top: 2px dashed #e8b05c;
            padding-top: 18px;
        }
        .modal-close {
            background: #e2ac5b;
            border: none;
            padding: 10px 28px;
            border-radius: 60px;
            font-weight: bold;
            margin-top: 26px;
            cursor: pointer;
            font-size: 1rem;
        }
        .purchase-final {
            background: #f7c16b;
            margin-left: 14px;
        }
    
        .social-block {
            margin: 28px 0;
            background: #2f261d;
            padding: 20px;
            border-radius: 40px;
        }
        .social-block a {
            display: inline-block;
            margin: 8px 28px 8px 0;
            font-size: 1.25rem;
            font-weight: 600;
            color: #fdde9e;
            text-decoration: none;
        }
        .instagram-wall-16x9 {
            margin-top: 22px;
            border-radius: 32px;
            overflow: hidden;
            border: 2px solid #d4a051;
        }
        .wall-img {
            width: 100%;
            aspect-ratio: 16 / 9;
            object-fit: cover;
            display: block;
        }
        .ig-credit {
            font-size: 0.7rem;
            text-align: center;
            margin-top: 8px;
            color: #e7bc78;
        }
        footer {
            text-align: center;
            opacity: 0.6;
            font-size: 0.7rem;
            margin-top: 30px;
        }
        @media (max-width: 1050px) {
            .products-five { gap: 18px; }
            .product-title { font-size: 0.95rem; }
            .price { font-size: 1.3rem; }
        }
        @media (max-width: 860px) {
